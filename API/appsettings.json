{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=JiraTrackDB;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "Secret": "JiraTrack-Super-Secret-Key-Min-32-Characters-Long-2026!",
    "Issuer": "JiraTrack",
    "Audience": "JiraTrackClient",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "AppSettings": {
    "FrontendUrl": "http://localhost:4200",
    "ExposeResetTokenInDev": true
  },
  "FileStorage": {
    "StoragePath": "UploadedFiles",
    "MaxImageSizeBytes": 10485760,
    "MaxDocumentSizeBytes": 26214400,
    "MaxVideoSizeBytes": 104857600
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "Origins": [ "http://localhost:4200" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
